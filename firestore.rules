rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /chats/{sessionId}/messages/{messageId} {
      // Any client can read messages for a session (required for real-time sync)
      allow read: if true;

      // Allow only creating new messages — no overwrites or deletes
      // Validates that required fields are present and content is within size limit
      allow create: if request.resource.data.keys().hasAll(['role', 'content', 'timestamp'])
                    && request.resource.data.role in ['user', 'assistant']
                    && request.resource.data.content is string
                    && request.resource.data.content.size() > 0
                    && request.resource.data.content.size() < 10000;

      // Prevent editing or deleting existing messages
      allow update, delete: if false;
    }

    // Deny all other paths by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}